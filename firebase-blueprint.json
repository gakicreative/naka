{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "description": "The user's email address." },
        "name": { "type": "string", "description": "The user's display name." },
        "role": { "type": "string", "enum": ["admin", "socio", "seeder", "cliente"], "description": "The user's role." },
        "activeClientId": { "type": "string", "description": "The ID of the client this user belongs to (if role is cliente)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "An invitation to join the platform as a staff member.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["socio", "seeder"], "description": "The role to grant the user." },
        "used": { "type": "boolean", "description": "Whether the invitation has been used." },
        "usedBy": { "type": "string", "description": "The UID of the user who used the invitation." },
        "createdBy": { "type": "string", "description": "The UID of the admin who created the invitation." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["role", "used", "createdBy", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a task",
      "type": "object",
      "properties": {
        "taskId": { "type": "string", "description": "The ID of the task this comment belongs to" },
        "text": { "type": "string", "description": "The content of the comment" },
        "image": { "type": "string", "description": "Optional image URL attached to the comment" },
        "sender": { "type": "string", "description": "The initial of the sender" },
        "senderName": { "type": "string", "description": "The name of the sender" },
        "senderId": { "type": "string", "description": "The UID of the sender" },
        "time": { "type": "string", "description": "The time the comment was posted" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of creation" }
      },
      "required": ["taskId", "sender", "senderName", "senderId", "time", "createdAt"]
    },
    "Pin": {
      "title": "Pin",
      "description": "A visual feedback pin on an image",
      "type": "object",
      "properties": {
        "taskId": { "type": "string", "description": "The ID of the task this pin belongs to" },
        "imageId": { "type": "string", "description": "The URL or ID of the image this pin is on" },
        "x": { "type": "number", "description": "X coordinate percentage" },
        "y": { "type": "number", "description": "Y coordinate percentage" },
        "text": { "type": "string", "description": "The comment text for this pin" },
        "resolved": { "type": "boolean", "description": "Whether the pin is resolved" },
        "author": { "type": "string", "description": "The name of the author" },
        "authorId": { "type": "string", "description": "The UID of the author" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of creation" }
      },
      "required": ["taskId", "imageId", "x", "y", "text", "resolved", "author", "authorId", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "A client of the agency.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this client." },
        "name": { "type": "string", "description": "The name of the client." },
        "industry": { "type": "string", "description": "The industry of the client." },
        "contact": { "type": "string", "description": "The contact person for the client." },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"], "description": "The status of the client." },
        "logo": { "type": "string", "description": "A single letter or short string for the logo." },
        "email": { "type": "string", "description": "Client email address." },
        "phone": { "type": "string", "description": "Client phone number." },
        "retainer": {
          "type": "object",
          "properties": {
            "value": { "type": "number" },
            "hours": { "type": "number" },
            "loggedHours": { "type": "number" },
            "renewalDate": { "type": "string" },
            "healthScore": { "type": "number" },
            "focus": { "type": "array", "items": { "type": "string" } }
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "email": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "name", "industry", "contact", "status", "logo"]
    },
    "BrandHub": {
      "title": "BrandHub",
      "description": "Brand identity and assets for a project.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "colors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "hex": { "type": "string" }
            }
          }
        },
        "fonts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "logos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "identity": {
          "type": "object",
          "properties": {
            "nicho": { "type": "string" },
            "publicoAlvo": { "type": "string" },
            "tomDeVoz": { "type": "string" },
            "slogan": { "type": "string" },
            "concorrentes": { "type": "string" },
            "restricoesVisuais": { "type": "string" }
          }
        },
        "figmaLink": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "projectId"]
    },
    "Deliverable": {
      "title": "Deliverable",
      "description": "A deliverable for a client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientId", "title", "type", "date", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "A project for a client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this project." },
        "name": { "type": "string", "description": "The name of the project." },
        "client": { "type": "string", "description": "The name or ID of the client." },
        "status": { "type": "string", "enum": ["Em Andamento", "Concluído", "Pausado"], "description": "The status of the project." },
        "progress": { "type": "number", "description": "The progress percentage of the project." },
        "dueDate": { "type": "string", "description": "The due date of the project." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "name", "client", "status", "progress", "dueDate"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this task." },
        "title": { "type": "string", "description": "The title of the task." },
        "priority": { "type": "string", "enum": ["Urgente", "Alta", "Média", "Baixa"], "description": "The priority of the task." },
        "date": { "type": "string", "description": "The due date or timeframe of the task." },
        "comments": { "type": "number", "description": "Number of comments." },
        "attachments": { "type": "number", "description": "Number of attachments." },
        "assignees": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "The people assigned to the task." 
        },
        "project": { "type": "string", "description": "The project this task belongs to." },
        "status": { "type": "string", "enum": ["todo", "in-progress", "review", "done"], "description": "The status of the task." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "title", "priority", "date", "comments", "attachments", "assignees", "project", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this transaction." },
        "description": { "type": "string", "description": "Description of the transaction." },
        "amount": { "type": "number", "description": "Amount of the transaction." },
        "type": { "type": "string", "enum": ["in", "out"], "description": "Type of the transaction (income or expense)." },
        "category": { "type": "string", "description": "Category of the transaction." },
        "date": { "type": "string", "description": "Date of the transaction (ISO string)." },
        "status": { "type": "string", "enum": ["Concluído", "Pendente"], "description": "Status of the transaction." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "description", "amount", "type", "category", "date", "status", "createdAt"]
    },
    "Attachment": {
      "title": "Attachment",
      "description": "A file attached to a task.",
      "type": "object",
      "properties": {
        "taskId": { "type": "string", "description": "The ID of the task this attachment belongs to." },
        "name": { "type": "string", "description": "The name of the file." },
        "url": { "type": "string", "description": "The download URL of the file." },
        "size": { "type": "number", "description": "The size of the file in bytes." },
        "type": { "type": "string", "description": "The MIME type of the file." },
        "uploaderId": { "type": "string", "description": "The UID of the user who uploaded the file." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["taskId", "name", "url", "size", "type", "uploaderId", "createdAt"]
    }
  },
  "firestore": {
    "/invitations/{invitationId}": {
      "schema": { "$ref": "#/entities/Invitation" },
      "description": "Stores invitations for staff members."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Stores financial transactions."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Stores client information."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores project information."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores task information."
    },
    "/tasks/{taskId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a task."
    },
    "/tasks/{taskId}/attachments/{attachmentId}": {
      "schema": { "$ref": "#/entities/Attachment" },
      "description": "Attachments on a task."
    },
    "/tasks/{taskId}/pins/{pinId}": {
      "schema": { "$ref": "#/entities/Pin" },
      "description": "Visual feedback pins on a task."
    }
  }
}
