# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/naka"

# JWT — use uma string aleatória segura
JWT_SECRET="troque-por-uma-string-aleatoria-segura"

# Google OAuth — gere em https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"
GOOGLE_CALLBACK_URL="https://okei.agency/api/auth/google/callback"

# Email do super-admin (pula a verificação de convite no primeiro cadastro)
ADMIN_EMAIL="admin@naka.app"

# Gemini AI (opcional)
GEMINI_API_KEY="sua-key-aqui"

# Porta do servidor (default: 3000)
PORT=3000
